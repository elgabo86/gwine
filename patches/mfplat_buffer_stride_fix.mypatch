             WARN("Couldn't unlock source buffer %p, hr %#lx.\n", iface, hr);
@@ -690,8 +690,8 @@ static HRESULT WINAPI memory_2d_buffer_ContiguousCopyFrom(IMF2DBuffer2 *iface, c
     {
