+            copy_image(buffer, rect.pBits, rect.Pitch, buffer->_2d.linear_buffer, rect.Pitch,
+                    rect.Pitch, buffer->_2d.height);
             IDirect3DSurface9_UnlockRect(buffer->d3d9_surface.surface);
         }
 
@@ -661,8 +661,8 @@ static HRESULT WINAPI memory_2d_buffer_ContiguousCopyTo(IMF2DBuffer2 *iface, BYT
     {
         if (src_pitch < 0)
             src_pitch = -src_pitch;
